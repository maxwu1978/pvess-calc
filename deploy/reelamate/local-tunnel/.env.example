PVESS_WEB_ACCESS_TOKEN=replace-with-a-long-random-token
PVESS_WEB_BASIC_AUTH_USER=tge
PVESS_WEB_BASIC_AUTH_PASSWORD=replace-with-a-long-random-basic-auth-password
PVESS_WEB_PORT=8765
PVESS_WEB_WORKDIR="$HOME/.pvess/reelamate-web"
PVESS_PUBLIC_BASE_URL=https://tge.reelamate.com

# Lead notification mode:
# - dry_run: store notification events only
# - webhook: POST new lead events to PVESS_LEAD_NOTIFICATION_WEBHOOK_URL
# - off: store skipped notification events
PVESS_LEAD_NOTIFICATION_MODE=dry_run
PVESS_LEAD_NOTIFICATION_WEBHOOK_URL=

# Optional online lookup providers. Leave blank for offline/simulated mode.
PVESS_MAPBOX_TOKEN=
PVESS_NREL_API_KEY=
PVESS_GOOGLE_SOLAR_KEY=
