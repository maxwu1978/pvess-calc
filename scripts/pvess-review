#!/usr/bin/env bash
# pvess-review — one-shot rebuild + doctor + rasterize for visual review.
#
# Usage:
#   ./scripts/pvess-review                              # default: phoenix project
#   ./scripts/pvess-review projects/003-austin/
#   ./scripts/pvess-review --no-permit                  # skip permit PDF
#   ./scripts/pvess-review projects/002-phoenix-25kw/ --open
#
# After this script exits, the rasterized PNGs live in /tmp/pvess_review-NN.png
# and can be inspected from the terminal, the Finder, or by a Claude session
# via Read.

set -euo pipefail

REPO_ROOT="$(cd "$(dirname "$0")/.." && pwd)"
cd "$REPO_ROOT"

# Default project (matches docs/TESTING.md §4 canonical fixture).
PROJECT="projects/002-phoenix-25kw/"
DO_PERMIT=1
DO_OPEN=0

# ─── Parse args ────────────────────────────────────────────────────────────
for arg in "$@"; do
  case "$arg" in
    projects/*)   PROJECT="$arg" ;;
    --no-permit)  DO_PERMIT=0 ;;
    --open)       DO_OPEN=1 ;;
    -h|--help)
      sed -n '2,12p' "$0"
      exit 0
      ;;
    *) echo "unknown arg: $arg"; exit 2 ;;
  esac
done

if [[ ! -d "$PROJECT" ]]; then
  echo "✗ project not found: $PROJECT"
  exit 2
fi

# ─── macOS quirk: unhide .pth files in venv ────────────────────────────────
# Editable install drops .pth files with UF_HIDDEN set inside the venv on
# macOS, which breaks site-packages discovery. Strip the flag every time.
for candidate in .venv venv; do
  chflags nohidden "$candidate"/lib/python*/site-packages/*.pth 2>/dev/null || true
done

if [[ -x "$REPO_ROOT/.venv/bin/pvess-calc" ]]; then
  VENV="$REPO_ROOT/.venv/bin"
elif [[ -x "$REPO_ROOT/venv/bin/pvess-calc" ]]; then
  VENV="$REPO_ROOT/venv/bin"
else
  VENV="$REPO_ROOT/.venv/bin"
fi
if [[ ! -x "$VENV/pvess-calc" ]]; then
  echo "✗ venv not set up. Run: python -m venv .venv && .venv/bin/pip install -e ."
  exit 2
fi

# ─── Read project metadata from inputs.yaml via Python (PyYAML in venv) ────
# BSD sed and quoted YAML strings don't get along; let PyYAML do the parsing.
# AHJ can contain spaces ("City of Phoenix"), so read line-by-line.
META="$("$VENV/python" - <<PY
import yaml
with open("$PROJECT/inputs.yaml") as f:
    d = yaml.safe_load(f)
proj = d.get("project") or {}
print(proj.get("id",""))
print(proj.get("ahj",""))
PY
)"
PROJECT_ID="$(printf '%s\n' "$META" | sed -n '1p')"
AHJ_RAW="$(printf '%s\n' "$META" | sed -n '2p')"

# Map AHJ to profile slug.
case "$AHJ_RAW" in
  "City of Phoenix")          AHJ_FLAG="--ahj phoenix_az" ;;
  "City of Austin")           AHJ_FLAG="--ahj austin_tx" ;;
  Hawaii*)                    AHJ_FLAG="--ahj hawaii_generic" ;;
  California*)                AHJ_FLAG="--ahj california_generic" ;;
  *)                          AHJ_FLAG="" ;;
esac

# ─── Step 1: Build everything ──────────────────────────────────────────────
echo "─── building $PROJECT (id=$PROJECT_ID, ahj=${AHJ_RAW:-—}) ───"

"$VENV/pvess-calc"   "$PROJECT" | tail -3
"$VENV/pvess-render" "$PROJECT" | tail -1
"$VENV/pvess-labels" "$PROJECT" | tail -1
"$VENV/pvess-dxf" --preview "$PROJECT" | tail -3

if [[ $DO_PERMIT -eq 1 ]]; then
  # shellcheck disable=SC2086
  "$VENV/pvess-permit" $AHJ_FLAG "$PROJECT" | tail -1
fi

# ─── Step 2: Doctor ────────────────────────────────────────────────────────
echo ""
echo "─── pvess-doctor ───"
"$VENV/pvess-doctor" "$PROJECT" || {
  echo ""
  echo "✗ pvess-doctor reported structural drift. Fix before reviewing visually."
  exit 1
}

# ─── Step 3: Rasterize permit PDF ──────────────────────────────────────────
PDF="$PROJECT/output/permit-package-$PROJECT_ID.pdf"

if [[ $DO_PERMIT -eq 1 && -f "$PDF" ]]; then
  echo ""
  echo "─── rasterizing $PDF ───"
  rm -f /tmp/pvess_review-*.png
  pdftoppm -r 110 -png "$PDF" /tmp/pvess_review
  N_PAGES="$(ls /tmp/pvess_review-*.png | wc -l | tr -d ' ')"
  echo "  wrote $N_PAGES pages → /tmp/pvess_review-NN.png"
fi

# ─── Step 4: Optionally open in macOS Preview ──────────────────────────────
if [[ $DO_OPEN -eq 1 && -f "$PDF" ]]; then
  open "$PDF"
fi

echo ""
echo "✓ ready for review"
echo "  PDF:    $PDF"
echo "  PNGs:   /tmp/pvess_review-NN.png"
echo "  QET:    $PROJECT/output/system.qet"
